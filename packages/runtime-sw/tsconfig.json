{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["WebWorker", "ES2024"],
    "module": "es2022",
    "moduleResolution": "bundler",
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "rewriteRelativeImportExtensions": true
  },
  "include": ["src"]
}
