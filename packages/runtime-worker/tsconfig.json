{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["WebWorker", "ES2024"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
